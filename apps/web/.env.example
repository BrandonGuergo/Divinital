# Canonical origin of the parent company site (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://divinital.com

# Where the Intralocutor splash page's primary CTA sends readers.
NEXT_PUBLIC_INTRALOCUTOR_APP_URL=https://intralocutor.com

# Resend credentials for the PayShroud waitlist (https://resend.com).
# Without these, the waitlist logs submissions in development and returns 503 in production.
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Optional: sender for the waitlist confirmation email. If unset, no email is sent.
RESEND_FROM_EMAIL="PayShroud <hello@payshroud.com>"
